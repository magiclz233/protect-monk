{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", ".tmp-tests"]
}
